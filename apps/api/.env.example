# Copy this file to .env (DO NOT commit .env)

# Gemini
GEMINI_API_KEY=
GEMINI_PLANNER_MODEL=gemini-2.0-flash
GEMINI_RENDERER_MODEL=gemini-2.0-flash

# Storage
# Where to save rendered keyframe images (local disk).
# Example (Windows): C:\Users\Administrator\Desktop\分镜图
KEYFRAMES_DIR=C:\Users\Administrator\Desktop\分镜图
